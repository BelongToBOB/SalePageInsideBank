---
// SeminarGallery.astro
const images = [
  "/asset/images/ISBseminar2.jpg", // Main large image
  "/asset/images/seminar/ibf-inclass.jpg",
  "/asset/images/seminar/ibf-inclass2.jpg",
  "/asset/images/seminar/ibf-inclass3.jpg",
  "/asset/images/seminar/ibf-inclass4.jpg",
  "/asset/images/seminar/ibf-inclass5.jpg",
  "/asset/images/seminar/ibf-inclass6.jpg",
  "/asset/images/seminar/ibf-inclass7.jpg",
  "/asset/images/seminar/ibf-inclass8.jpg",
  "/asset/images/seminar/ibf-inclass9.jpg",
  "/asset/images/seminar/ibf-inclass10.jpg",
  "/asset/images/seminar/ibf-inclass11.jpg",
  "/asset/images/seminar/ibf-inclass12.jpg"
];
---
<section class="py-20 bg-[#0a0a0a] border-t border-yellow-500/10 relative overflow-hidden">
  
  {/* Decorative Ambient Glow (Softened for a cleaner look) */}
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-yellow-900/10 blur-[120px] rounded-full mix-blend-screen pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-12 max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4 tracking-tight leading-tight">
        บรรยากาศการสัมมนาและ<br class="hidden sm:block"/>แชร์ประสบการณ์ธุรกิจ
      </h2>
      <p class="text-lg md:text-xl text-gray-400 font-light leading-relaxed">
        คลาสเรียน "Inside Business Finance" และการให้คำปรึกษากับผู้ประกอบการ SME
      </p>
    </div>

    {/* Layout Group */}
    <div class="flex flex-col gap-6 md:gap-8">
      
      {/* 1. Large Hero Image */}
      <div class="group relative w-full h-[50vh] md:h-[60vh] overflow-hidden rounded-2xl md:rounded-3xl shadow-2xl bg-neutral-950 border border-white/5 ring-1 ring-white/10">
        <img 
          src={images[0]} 
          alt="บรรยากาศงานสัมมนาขนาดใหญ่ Win WinWealth Creation" 
          class="w-full h-full object-cover transition-transform duration-1000 ease-out group-hover:scale-105"
          loading="lazy"
        />
        {/* Subtle overlay for contrast */}
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent opacity-70 mix-blend-multiply transition-opacity duration-500 group-hover:opacity-50"></div>
      </div>

      {/* 2. Smaller Image Gallery (Masonry Layout for a clean, uncluttered visual) */}
      <div class="columns-2 md:columns-3 lg:columns-4 gap-4 md:gap-6 py-2 px-1 space-y-4 md:space-y-6">
        {images.slice(1).map((src, index) => (
          <div class="group relative break-inside-avoid overflow-hidden rounded-xl md:rounded-2xl bg-neutral-900 border border-white/5 shadow-[0_4px_20px_-10px_rgba(0,0,0,0.5)]">
            <img 
              src={src} 
              alt={`ภาพบรรยากาศคลาสเรียนและสัมมนา ${index + 1}`} 
              class="w-full h-auto object-cover transition-transform duration-700 ease-out group-hover:scale-105"
              loading="lazy"
            />
            {/* Inner ring & subtle overlay on hover to feel premium and comfortable */}
            <div class="absolute inset-0 ring-1 ring-inset ring-white/10 pointer-events-none rounded-xl md:rounded-2xl"></div>
            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 mix-blend-overlay pointer-events-none"></div>
          </div>
        ))}
      </div>
      
    </div>
  </div>
</section>
